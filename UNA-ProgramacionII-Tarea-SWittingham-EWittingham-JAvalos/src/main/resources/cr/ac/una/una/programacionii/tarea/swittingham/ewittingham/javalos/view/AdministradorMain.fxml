<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ToggleButton?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefHeight="400.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="cr.ac.una.una.programacionii.tarea.swittingham.ewittingham.javalos.controller.AdministradorMainController">
    <left>
        <VBox prefWidth="220.0">
            <children>
                <HBox alignment="CENTER" prefHeight="80.0">
                    <children>
                        <ImageView fitHeight="60.0" fitWidth="60.0" preserveRatio="true" />
                        <Label text="Trámites UNA" />
                    </children>
                </HBox>
                <VBox spacing="5.0">
                    <ToggleButton fx:id="btnDashboard" prefWidth="200.0" selected="true" text="Dashboard / Gráficos" />
                    <ToggleButton fx:id="btnTramites" onAction="#showProcedure" prefWidth="200.0" text="Trámites" />
                    <ToggleButton fx:id="btnCustomers" onAction="#showClients" prefWidth="200.0" text="Clientes" />
                    <ToggleButton fx:id="btnSucursales" onAction="#showBranchesAndStations" prefWidth="200.0" text="Sucursales y Estaciones" />
                </VBox>
                <VBox VBox.vgrow="ALWAYS" />
                <VBox alignment="CENTER" spacing="8.0">
                    <ImageView fitHeight="48.0" fitWidth="48.0" preserveRatio="true" />
                    <Label text="Stephany" />
                    <Label text="Administrador" />
                    <Button fx:id="btnSalir" prefWidth="180.0" text="Salir" />
                </VBox>
            </children>
        </VBox>
    </left>
    <center>
        <StackPane fx:id="contentArea" />
    </center>
</BorderPane>
