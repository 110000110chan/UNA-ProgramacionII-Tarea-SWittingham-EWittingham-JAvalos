<?xml version="1.0" encoding="UTF-8"?>

<?import io.github.palexdev.materialfx.controls.MFXButton?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefHeight="400.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="cr.ac.una.una.programacionii.tarea.swittingham.ewittingham.javalos.controller.AdministratorMainController">
    <left>
        <VBox prefHeight="400.0" prefWidth="190.0">
            <children>
                <HBox alignment="CENTER" prefHeight="80.0">
                    <children>
                        <ImageView fitHeight="60.0" fitWidth="60.0" preserveRatio="true" />
                        <Label text="Trámites UNA" />
                    </children>
                </HBox>
                <VBox spacing="10.0">
               <HBox spacing="10.0">
                  <children>
                     <ImageView fitHeight="32.0" fitWidth="33.0" pickOnBounds="true" preserveRatio="true">
                        <image>
                           <Image url="@../resources/DashboardIcon.png" />
                        </image></ImageView>
                     <MFXButton fx:id="btnDashboard" maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308" onAction="#showDashboard" text="Dashboard" HBox.hgrow="ALWAYS" />
                  </children>
               </HBox>
               <HBox spacing="10.0">
                  <children>
                     <ImageView fitHeight="32.0" fitWidth="33.0" pickOnBounds="true" preserveRatio="true">
                        <image>
                           <Image url="@../resources/ProceduresIcon.png" />
                        </image></ImageView>
                     <MFXButton fx:id="btnProcedures" maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308" onAction="#showProcedures" text="Trámites" HBox.hgrow="ALWAYS" />
                  </children>
               </HBox>
               <HBox spacing="10.0">
                  <children>
                     <ImageView fitHeight="32.0" fitWidth="33.0" pickOnBounds="true" preserveRatio="true">
                        <image>
                           <Image url="@../resources/CustomersIcon.png" />
                        </image></ImageView>
                     <MFXButton fx:id="btnCustomers" maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308" onAction="#showCustomers" text="Clientes" HBox.hgrow="ALWAYS" />
                  </children>
               </HBox>
               <HBox spacing="10.0">
                  <children>
                     <ImageView fitHeight="32.0" fitWidth="33.0" pickOnBounds="true" preserveRatio="true">
                        <image>
                           <Image url="@../resources/LocationsIcon.png" />
                        </image></ImageView>
                     <MFXButton fx:id="btnLocations" maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308" onAction="#showLocations" text="Localidades" HBox.hgrow="ALWAYS" />
                  </children>
               </HBox>
                </VBox>
                <VBox alignment="BOTTOM_CENTER" spacing="8.0" VBox.vgrow="ALWAYS">
                    <ImageView fitHeight="48.0" fitWidth="48.0" preserveRatio="true" />
                    <Label text="Stephany" />
                    <Label text="Administrador" />
               <MFXButton fx:id="btnExit" maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308" text="Salir" />
                </VBox>
            </children>
        </VBox>
    </left>
    <center>
        <StackPane fx:id="contentArea" />
    </center>
   <padding>
      <Insets left="10.0" />
   </padding>
</BorderPane>
