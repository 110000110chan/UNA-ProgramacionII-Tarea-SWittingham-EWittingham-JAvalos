<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Tab?>
<?import javafx.scene.control.TabPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<AnchorPane prefHeight="400.0" prefWidth="600.0" styleClass="mainFxmlClass" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="cr.ac.una.una.programacionii.tarea.swittingham.ewittingham.javalos.controller.CustomersController">

    <children>
        <VBox alignment="TOP_CENTER" spacing="12.0" AnchorPane.bottomAnchor="0" AnchorPane.leftAnchor="0" AnchorPane.rightAnchor="0" AnchorPane.topAnchor="0">

            <!-- Toolbar superior -->
            <HBox alignment="CENTER_LEFT" spacing="12.0">
                <children>
                    <TextField fx:id="txtBuscar" promptText="Buscar por cédula, nombre o apellidos..." HBox.hgrow="ALWAYS" />
                    <Button fx:id="btnBuscar" text="Buscar" />
                    <Button fx:id="btnNuevo" text="Nuevo Cliente" />
                    <Button fx:id="btnRefrescar" text="Refrescar" />
                </children>
            </HBox>
                 <TabPane fx:id="tabPaneClientes" maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308" prefHeight="200.0" prefWidth="200.0" tabClosingPolicy="UNAVAILABLE" VBox.vgrow="ALWAYS">
           <tabs>
                         <Tab fx:id="tabBusquedaClientes" text="Busqueda de clientes">
               <content>
                 <AnchorPane minHeight="0.0" minWidth="0.0" prefHeight="180.0" prefWidth="200.0">
                        <children>
                                                <TableView fx:id="tblClientes" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
                                  <columns>
                                      <TableColumn fx:id="colFoto" maxWidth="100.0" minWidth="70.0" prefWidth="80.0" resizable="false" text="Foto" />
                  
                                                  <TableColumn fx:id="colCedula" prefWidth="120.0" text="Cédula" />
                                      <TableColumn fx:id="colNombre" prefWidth="220.0" text="Nombre Completo" />
                                      <TableColumn fx:id="colEdad" prefWidth="70.0" text="Edad" />
                                      <TableColumn fx:id="colFechaNacimiento" prefWidth="140.0" text="Fecha Nacimiento" />
                                      <TableColumn fx:id="colTelefono" prefWidth="130.0" text="Teléfono" />
                                      <TableColumn fx:id="colEmail" prefWidth="200.0" text="Email" />
                                      <TableColumn fx:id="colFechaRegistro" prefWidth="140.0" text="Registrado" />
                                      <TableColumn fx:id="colAcciones" prefWidth="160.0" resizable="false" text="Acciones" />
                                  </columns>
                  
                                              <placeholder>
                                      <Label style="-fx-font-size: 14; -fx-text-fill: #666666;" text="No hay clientes registrados" />
                                  </placeholder>
                              </TableView>
                        </children>
                        <padding>
                           <Insets left="10.0" right="10.0" top="10.0" />
                        </padding>
                     </AnchorPane>
               </content>
             </Tab>
             <Tab fx:id="tabRegistroCliente" text="Registro de cliente">
                 <content>
                     <AnchorPane maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308" minHeight="0.0" minWidth="0.0" prefHeight="180.0" prefWidth="200.0">
                         <children>
                             <ScrollPane fitToHeight="true" fitToWidth="true" hbarPolicy="NEVER" maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308" prefViewportHeight="200.0" prefViewportWidth="200.0" vbarPolicy="AS_NEEDED" AnchorPane.bottomAnchor="20.0" AnchorPane.leftAnchor="20.0" AnchorPane.rightAnchor="20.0" AnchorPane.topAnchor="20.0">
                                 <content>
                                     <StackPane maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308">
                                         <children>
                                             <VBox fx:id="paneFormularioCliente" fillWidth="true" maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308" spacing="16.0">
                                                 <children>
                                                     <VBox maxWidth="1.7976931348623157E308" spacing="12.0" VBox.vgrow="ALWAYS">
                                                         <children>
                                                             <VBox maxWidth="1.7976931348623157E308" spacing="4.0">
                                                                 <children>
                                                                     <Label text="Cédula:" />
                                                                     <TextField fx:id="txtRegCedula" maxWidth="1.7976931348623157E308" />
                                                                 </children>
                                                             </VBox>
                                                             <VBox maxWidth="1.7976931348623157E308" spacing="4.0">
                                                                 <children>
                                                                     <Label text="Nombre Completo:" />
                                                                     <TextField fx:id="txtRegNombre" maxWidth="1.7976931348623157E308" />
                                                                 </children>
                                                             </VBox>
                                                             <VBox maxWidth="1.7976931348623157E308" spacing="4.0">
                                                                 <children>
                                                                     <Label text="Fecha de Nacimiento:" />
                                                                     <DatePicker fx:id="dpRegFechaNacimiento" editable="true" maxWidth="1.7976931348623157E308" />
                                                                 </children>
                                                             </VBox>
                                                             <VBox maxWidth="1.7976931348623157E308" spacing="4.0">
                                                                 <children>
                                                                     <Label text="Teléfono:" />
                                                                     <TextField fx:id="txtRegTelefono" maxWidth="1.7976931348623157E308" />
                                                                 </children>
                                                             </VBox>
                                                             <VBox maxWidth="1.7976931348623157E308" spacing="4.0">
                                                                 <children>
                                                                     <Label text="Email:" />
                                                                     <TextField fx:id="txtRegEmail" maxWidth="1.7976931348623157E308" />
                                                                 </children>
                                                             </VBox>
                                                         </children>
                                                     </VBox>

                                                     <HBox alignment="CENTER" maxWidth="1.7976931348623157E308" spacing="12.0">
                                                         <children>
                                                             <Button fx:id="btnAgregarFoto" maxWidth="1.7976931348623157E308" text="Agregar o Tomar Foto" HBox.hgrow="ALWAYS" />
                                                             <Button fx:id="btnGuardarCliente" maxWidth="1.7976931348623157E308" style="-fx-background-color: #2a8b3e; -fx-text-fill: white; -fx-font-weight: bold;" text="Guardar Cliente" HBox.hgrow="ALWAYS" />
                                                             <Button fx:id="btnLimpiarFormulario" maxWidth="1.7976931348623157E308" text="Limpiar Datos" HBox.hgrow="ALWAYS" />
                                                         </children>
                                                     </HBox>
                                                 </children>
                                             </VBox>

                                             <VBox fx:id="paneFotoCliente" alignment="TOP_CENTER" managed="false" maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308" spacing="15.0" style="-fx-border-color: #cccccc; -fx-border-radius: 5; -fx-padding: 15;" visible="false">
                                                 <children>
                                                     <Label style="-fx-font-weight: bold;" text="Fotografía del Cliente" VBox.vgrow="ALWAYS" />
                                                     <ImageView fx:id="imgViewFoto" fitHeight="180.0" fitWidth="180.0" pickOnBounds="true" preserveRatio="true" />
                                                     <HBox alignment="CENTER" spacing="10.0">
                                                         <children>
                                                             <Button fx:id="btnSeleccionarFoto" text="Buscar Foto..." />
                                                             <Button fx:id="btnTomarFoto" text="Tomar Foto" />
                                                         </children>
                                                     </HBox>
                                                     <Button fx:id="btnVolverFormulario" text="Volver al Formulario" />
                                                     <Label fx:id="lblRutaFoto" style="-fx-text-fill: gray; -fx-font-size: 10px;" text="Ninguna foto seleccionada" wrapText="true" VBox.vgrow="ALWAYS" />
                                                 </children>
                                             </VBox>
                                         </children>
                                     </StackPane>
                                 </content>
                              <padding>
                                 <Insets left="10.0" right="10.0" top="10.0" />
                              </padding>
                             </ScrollPane>
                         </children>
                     </AnchorPane>
                 </content>
             </Tab>
           </tabs>
         </TabPane>
            <HBox alignment="CENTER_LEFT" spacing="20.0" style="-fx-padding: 8 0 0 0;">
                <children>
                    <Label fx:id="lblTotalClientes" text="Total clientes: 0" />
                    <Label fx:id="lblFiltroActivo" style="-fx-text-fill: #0066cc;" text="" />
                </children>
            </HBox>

        </VBox>
    </children>
   <padding>
      <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
   </padding>
</AnchorPane>
