<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="cr.ac.una.una.programacionii.tarea.swittingham.ewittingham.javalos.controller.AdministradorMainController"
            prefHeight="400.0" prefWidth="600.0">
    <left>
        <VBox prefWidth="220.0">
            <children>
                <HBox alignment="CENTER" prefHeight="80.0">
                    <children>
                        <ImageView fitHeight="60.0" fitWidth="60.0" preserveRatio="true" />
                        <Label text="Trámites UNA" />
                    </children>
                </HBox>
                <VBox spacing="5.0">
                    <ToggleButton fx:id="btnDashboard"   text="Dashboard / Gráficos"   prefWidth="200.0" selected="true" />
                    <ToggleButton fx:id="btnTramites"    text="Trámites"               prefWidth="200.0" />
                    <ToggleButton fx:id="btnClientes"    text="Clientes"               prefWidth="200.0" />
                    <ToggleButton fx:id="btnSucursales"  text="Sucursales y Estaciones" prefWidth="200.0" />
                </VBox>
                <VBox VBox.vgrow="ALWAYS" />
                <VBox spacing="8.0" alignment="CENTER">
                    <ImageView fitHeight="48.0" fitWidth="48.0" preserveRatio="true" />
                    <Label text="Stephany" />
                    <Label text="Administrador" />
                    <Button fx:id="btnSalir" text="Salir" prefWidth="180.0" />
                </VBox>
            </children>
        </VBox>
    </left>
    <center>
        <StackPane fx:id="contentArea" />
    </center>
</BorderPane>