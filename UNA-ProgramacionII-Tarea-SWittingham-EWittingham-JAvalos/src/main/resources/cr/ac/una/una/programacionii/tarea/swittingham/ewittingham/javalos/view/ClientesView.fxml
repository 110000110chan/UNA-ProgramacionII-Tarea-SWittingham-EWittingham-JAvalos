<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<AnchorPane prefHeight="400.0" prefWidth="600.0" styleClass="mainFxmlClass" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="cr.ac.una.una.programacionii.tarea.swittingham.ewittingham.javalos.controller.ClientesController">

    <children>
        <VBox alignment="TOP_CENTER" spacing="12.0" AnchorPane.bottomAnchor="0" AnchorPane.leftAnchor="0" AnchorPane.rightAnchor="0" AnchorPane.topAnchor="0">

            <!-- Toolbar superior -->
            <HBox alignment="CENTER_LEFT" spacing="12.0">
                <children>
                    <TextField fx:id="txtBuscar" promptText="Buscar por cédula, nombre o apellidos..." HBox.hgrow="ALWAYS" />
                    <Button fx:id="btnBuscar" text="Buscar" />
                    <Button fx:id="btnNuevo" text="Nuevo Cliente" />
                    <Button fx:id="btnRefrescar" text="Refrescar" />
                </children>
            </HBox>

            <!-- Tabla principal de clientes -->
            <TableView fx:id="tblClientes" VBox.vgrow="ALWAYS">
                <columns>
                    <!-- Foto pequeña (thumbnail) -->
                    <TableColumn fx:id="colFoto" maxWidth="100.0" minWidth="70.0" prefWidth="80.0" resizable="false" text="Foto" />

                    <TableColumn fx:id="colCedula" prefWidth="120.0" text="Cédula" />
                    <TableColumn fx:id="colNombre" prefWidth="220.0" text="Nombre Completo" />
                    <TableColumn fx:id="colEdad" prefWidth="70.0" text="Edad" />
                    <TableColumn fx:id="colFechaNacimiento" prefWidth="140.0" text="Fecha Nacimiento" />
                    <TableColumn fx:id="colTelefono" prefWidth="130.0" text="Teléfono" />
                    <TableColumn fx:id="colEmail" prefWidth="200.0" text="Email" />
                    <TableColumn fx:id="colFechaRegistro" prefWidth="140.0" text="Registrado" />
                    <TableColumn fx:id="colAcciones" prefWidth="160.0" resizable="false" text="Acciones" />
                </columns>

                <placeholder>
                    <Label style="-fx-font-size: 14; -fx-text-fill: #666666;" text="No hay clientes registrados" />
                </placeholder>
            </TableView>

            <!-- Barra de estado inferior -->
            <HBox alignment="CENTER_LEFT" spacing="20.0" style="-fx-padding: 8 0 0 0;">
                <children>
                    <Label fx:id="lblTotalClientes" text="Total clientes: 0" />
                    <Label fx:id="lblFiltroActivo" style="-fx-text-fill: #0066cc;" text="" />
                </children>
            </HBox>

        </VBox>
    </children>
   <padding>
      <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
   </padding>
</AnchorPane>
